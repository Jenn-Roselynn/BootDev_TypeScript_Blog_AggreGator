# Dependency directories
node_modules/
jspm_packages/

# TypeScript compilation output
dist/
out/

# Exclude compiled JS files generated from TS files in the src folder
# This keeps our TypeScript source clean if we run an in-place compile
src/**/*.js
src/**/*.d.ts
src/**/*.js.map

# Local configuration files and environment secrets
.env
.env.local
.env.*.local
.gatorconfig.json
*.local.json

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log

# Operating System files
.DS_Store
Thumbs.db